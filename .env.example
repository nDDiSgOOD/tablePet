# DeepSeek LLM
DEEPSEEK_API_KEY=
DEEPSEEK_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash

# ASR (faster-whisper)
TABLEPET_ASR_MODEL=small
TABLEPET_ASR_COMPUTE_TYPE=int8
TABLEPET_ASR_BEAM_SIZE=1
TABLEPET_ASR_MIN_AUDIO_MS=360
TABLEPET_ASR_MIN_RMS=80
TABLEPET_ASR_STRONG_RETRY_ENABLED=0
TABLEPET_ASR_STRONG_RETRY_MIN_AUDIO_MS=650
TABLEPET_ASR_STRONG_RETRY_MIN_RMS=450

# TTS
TABLEPET_TTS_VOICE=zh-TW-HsiaoChenNeural
TABLEPET_TTS_EDGE_ENABLED=0
TABLEPET_TTS_EDGE_RETRY_SECONDS=20
TABLEPET_TTS_CUTE_FILTER_ENABLED=0
TABLEPET_MACOS_SAY_VOICE="Flo (Chinese (China mainland))"

# Weather (wttr.in)
TABLEPET_WEATHER_LOCATION=Toronto

# ffmpeg (auto-detected if empty)
FFMPEG_BIN=

# USB serial bridge
TABLEPET_USB_ENABLED=1
TABLEPET_USB_PORT=auto
TABLEPET_USB_BAUD=921600
TABLEPET_USB_DEVICE_ID=tablepet-xiao-s3-001
TABLEPET_USB_MAX_PAYLOAD=3145728
